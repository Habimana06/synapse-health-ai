# Server
PORT=5000
NODE_ENV=development
APP_NAME=Synapse Health AI

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=62001
DB_NAME=synapse_health_ai

# JWT Authentication
JWT_SECRET=Synapse_Health_AI_JWT_Secret_2026_Change_In_Production
JWT_EXPIRES_IN=7d

# Groq AI (Grok-compatible — keys starting with gsk_)
GROQ_API_KEY=your-groq-api-key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (optional fallback)
OPENAI_API_KEY=

# Google Maps (optional)
GOOGLE_MAPS_API_KEY=

# Frontend URL (CORS)
CLIENT_URL=http://localhost:5173

# Email (SMTP)
MAIL_ENABLED=true
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME=Synapse Health AI

# Twilio SMS
SMS_ENABLED=true
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890
